  {
    "id": "templating.0010",
    "section": "§5.3.5",
    "profile": "templating",
    "operation": "templating.merge_frontmatter",
    "assertion": "envelope_equals",
    "requires": [
      "templating"
    ],
    "input": {
      "baseFrontmatter": {
        "title": "A",
        "status": "open",
        "priority": "normal"
      },
      "templateFrontmatter": {
        "title": "B",
        "status": "done",
        "project": "X"
      },
      "expected": {
        "title": "A",
        "status": "open",
        "priority": "normal",
        "project": "X"
      }
    },
    "expect": {
      "ok": true,
      "result": {
        "value": {
          "title": "A",
          "status": "open",
          "priority": "normal",
          "project": "X"
        }
      }
    }
  },
  {
    "id": "templating.0011",
    "section": "§5.3.5",
    "profile": "templating",
    "operation": "templating.merge_frontmatter",
    "assertion": "envelope_equals",
    "requires": [
      "templating"
    ],
    "input": {
      "baseFrontmatter": {
        "title": "A",
        "tags": [
          "one"
        ]
      },
      "templateFrontmatter": {
        "tags": [
          "two"
        ],
        "extra": true
      },
      "expected": {
        "title": "A",
        "tags": [
          "one"
        ],
        "extra": true
      }
    },
    "expect": {
      "ok": true,
      "result": {
        "value": {
          "title": "A",
          "tags": [
            "one"
          ],
          "extra": true
        }
      }
    }
  },
  {
    "id": "templating.0012",
    "section": "§5.3.5",
    "profile": "templating",
    "operation": "templating.create_pipeline",
    "assertion": "envelope_equals",
    "requires": [
      "templating"
    ],
    "input": {
      "baseFrontmatter": {
        "title": "Base title",
        "status": "open",
        "priority": "normal"
      },
      "templateFrontmatter": {
        "title": "Template title",
        "status": "done",
        "project": "A"
      },
      "callerBody": "Caller body",
      "templateBody": "Template body",
      "expectedFrontmatter": {
        "title": "Base title",
        "status": "open",
        "priority": "normal",
        "project": "A"
      },
      "expectedBody": "Template body"
    },
    "expect": {
      "ok": true,
      "result": {
        "frontmatter": {
          "title": "Base title",
          "status": "open",
          "priority": "normal",
          "project": "A"
        },
        "body": "Template body"
      }
    }
  },
  {
    "id": "templating.0013",
    "section": "§5.3.5",
    "profile": "templating",
    "operation": "templating.create_pipeline",
    "assertion": "envelope_equals",
    "requires": [
      "templating"
    ],
    "input": {
      "baseFrontmatter": {
        "title": "Base title",
        "status": "open"
      },
      "templateFrontmatter": {
        "status": "done",
        "project": "A"
      },
      "callerBody": "Caller body",
      "templateBody": "",
      "expectedFrontmatter": {
        "title": "Base title",
        "status": "open",
        "project": "A"
      },
      "expectedBody": "Caller body"
    },
    "expect": {
      "ok": true,
      "result": {
        "frontmatter": {
          "title": "Base title",
          "status": "open",
          "project": "A"
        },
        "body": "Caller body"
      }
    }
  },
  {
    "id": "templating.0014",
    "section": "§5.3.5",
    "profile": "templating",
    "operation": "templating.handle_failure",
    "assertion": "envelope_error",
    "requires": [
      "templating"
    ],
    "input": {
      "failureMode": "error",
      "errorCode": "template_missing",
      "shouldError": true
    },
    "expect": {
      "error": {
        "$regex": "template_missing|template_parse_failed|template"
      }
    }
  },
  {
    "id": "templating.0015",
    "section": "§5.3.5",
    "profile": "templating",
    "operation": "templating.handle_failure",
    "assertion": "envelope_equals",
    "requires": [
      "templating"
    ],
    "input": {
      "failureMode": "warning_fallback",
      "errorCode": "template_parse_failed",
      "shouldError": false
    },
    "expect": {
      "ok": true,
      "result": {
        "mode": "fallback"
      }
    }
  },
  {
    "id": "templating.0016",
    "section": "§9.14",
    "profile": "templating",
    "operation": "templating.config_defaults",
    "assertion": "envelope_equals",
    "requires": [
